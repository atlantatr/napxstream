<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- TV box'larda da çalışsın; kamera/dokunma zorunlu değil -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".XtreamApp"
        android:allowBackup="true"
        android:banner="@drawable/tv_banner"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Napxstream"
        tools:targetApi="34">

        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="com.napxstream.cast.CastOptionsProvider" />

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Napxstream.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.napxstream.action.SHORTCUT_LIVE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.napxstream.action.SHORTCUT_VOD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.napxstream.action.SHORTCUT_SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Napxstream.NoActionBar" />

        <activity
            android:name=".ui.player.PlayerActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:theme="@style/Theme.Napxstream.Player" />

        <activity
            android:name=".ui.vod.MovieDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Napxstream.NoActionBar" />

        <activity
            android:name=".ui.series.SeriesDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Napxstream.NoActionBar" />

        <activity
            android:name=".ui.m3u.M3uDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Napxstream.NoActionBar" />

        <activity
            android:name=".ui.epg.EpgTimelineActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Napxstream.NoActionBar" />

    </application>

</manifest>
