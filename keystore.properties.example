# Bu dosyayı "keystore.properties" olarak kopyalayıp gerçek değerlerinizi girin.
# keystore.properties ASLA repoya eklenmemelidir (bkz. .gitignore).
#
# Keystore oluşturmak için (Android Studio: Build > Generate Signed Bundle/APK > Create new...)
# veya terminalden:
#   keytool -genkey -v -keystore napxstream-release.keystore -alias napxstream \
#     -keyalg RSA -keysize 2048 -validity 10000

storeFile=../napxstream-release.keystore
storePassword=STORE_SIFRENIZ
keyAlias=napxstream
keyPassword=KEY_SIFRENIZ
